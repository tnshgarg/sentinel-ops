# `.env` template тАФ copy to `.env` and fill in values
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
HF_TOKEN=hf_your_token_here
ENV_URL=http://localhost:7860

# Set ENABLE_VISION=true when using a vision-capable model (e.g. Llama-3.2-11B-Vision-Instruct)
# to have the agent actually analyse surveillance frame images.
ENABLE_VISION=false
